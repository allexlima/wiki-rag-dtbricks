# Lakebase PostgreSQL credentials
# Get these from your Databricks Lakebase instance
LAKEBASE_HOST=your-lakebase-host.cloud.databricks.com
LAKEBASE_PORT=5432
LAKEBASE_DB=databricks_postgres
LAKEBASE_USER=your-email@company.com
LAKEBASE_PASSWORD=your-oauth-token-or-password

# MediaWiki secrets (generate with: openssl rand -hex 32)
MW_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
MW_UPGRADE_KEY=changeme_generate_with_openssl_rand_hex_16
